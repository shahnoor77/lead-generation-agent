# App
APP_ENV=development
LOG_LEVEL=INFO

# LLM — Ollama (local, no API key required)
OLLAMA_BASE_URL=http://12345678:11434
# Primary model: structured JSON tasks (ICP scoring, outreach drafts)
OLLAMA_MODEL=qwen2.5-coder:14b
# Summarization model: qwen2.5:1.5b — fast (2-5s), sufficient for 2-3 sentence summaries
OLLAMA_SUMMARIZE_MODEL=qwen2.5:1.5b

# Database — PostgreSQL
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=

# Auth
SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Sandbox outreach (test SMTP routing). Set false in production.
SANDBOX_OUTREACH_ENABLED=true
# Frontend: hide Test run + Settings sandbox panel (NEXT_PUBLIC_* is build-time).
# NEXT_PUBLIC_ENABLE_SANDBOX_UI=false

# Parallel workers processing one IMAP poll batch (faster replies; one IMAP fetch still).
OUTREACH_INBOX_PARALLEL_WORKERS=5
# How often the pipeline companion polls inbox during lead-gen (seconds).
OUTREACH_INBOX_POLL_INTERVAL_SEC=300

# After repeated IMAP login failure, skip polling for this many seconds (default 15 min).
OUTREACH_IMAP_AUTH_COOLDOWN_SEC=900

# Docker-specific environment variables
# Override these in docker-compose.yml or .env file

# API Security (CHANGE THESE IN PRODUCTION)
SECRET_KEY=abcdeiiii778882hhdiahdihai
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (must match docker-compose.yml)
# DATABASE_URL is set in docker-compose.yml

# Ollama LLM endpoint (Docker Desktop: use host.docker.internal)
# Docker on Linux: use your machine's IP or docker network hostname
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_SUMMARIZE_MODEL=qwen2.5:1.5b

# App
APP_ENV=production
LOG_LEVEL=INFO

# Sandbox outreach
SANDBOX_OUTREACH_ENABLED=true

# Outreach polling
OUTREACH_INBOX_PARALLEL_WORKERS=5
OUTREACH_INBOX_POLL_INTERVAL_SEC=300
